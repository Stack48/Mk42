// ── Enums ──────────────────────────────────────────────────────────────────────

enum TypeApporteur {
  PARTICULIER
  PROFESSIONNEL
}

enum StatutKYC {
  EN_ATTENTE
  VALIDE
  REFUSE
}

enum StatutOpportunite {
  SOUMISE
  ACCEPTEE
  REFUSEE
  EN_NEGOCIATION
}

enum StatutChantier {
  PROSPECTION
  CHIFFRAGE
  SIGNE
  EN_COURS
  TERMINE
}

enum StatutContrat {
  GENERE
  EN_ATTENTE_SIGNATURE
  SIGNE
  EXPIRE
}

enum StatutFacture {
  GENEREE
  ENVOYEE
  PAYEE
  ANNULEE
}

enum TypeDocument {
  CONTRAT
  FACTURE
  RECU
  KYC_IDENTITE
  KYC_KBIS
  KYC_DOMICILE
  RIB
  DAS2_EXPORT
}

// ── Modèles ────────────────────────────────────────────────────────────────────

model Utilisateur {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entreprise Entreprise?
  apporteur  Apporteur?
}

model Entreprise {
  id                   String    @id @default(cuid())
  utilisateurId        String    @unique
  utilisateur          Utilisateur @relation(fields: [utilisateurId], references: [id])
  raisonSociale        String
  siret                String    @unique
  adresseSiege         String
  codeApe              String?
  representantLegal    String?
  telephone            String?
  email                String?
  iban                 String?
  bic                  String?
  nomTitulaireIban     String?
  tauxCommissionDefaut Float?
  montantFixeDefaut    Float?
  statutKyc            StatutKYC @default(EN_ATTENTE)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  opportunites Opportunite[]
  chantiers    Chantier[]
  contrats     Contrat[]
  factures     Facture[]
  das2         DAS2[]
}

model Apporteur {
  id            String        @id @default(cuid())
  utilisateurId String        @unique
  utilisateur   Utilisateur   @relation(fields: [utilisateurId], references: [id])
  type          TypeApporteur
  nom           String
  prenom        String
  telephone     String?
  adresse       String?
  iban          String?
  bic           String?
  raisonSociale String?
  siret         String?
  numeroTva     String?
  dateNaissance DateTime?
  lieuNaissance String?
  statutKyc     StatutKYC     @default(EN_ATTENTE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  opportunites Opportunite[]
  contrats     Contrat[]
  factures     Facture[]
  recus        Recu[]
}

model Client {
  id               String   @id @default(cuid())
  estProfessionnel Boolean  @default(false)
  nom              String?
  prenom           String?
  raisonSociale    String?
  siret            String?
  telephone        String
  email            String
  adresseSiege     String?
  adresseChantier  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  opportunites Opportunite[]
}

model Opportunite {
  id            String            @id @default(cuid())
  apporteurId   String
