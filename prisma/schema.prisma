// ─── ENTREPRISE ──────────────────────────────────────────────────────────────
model Entreprise {
  id            String  @id @default(cuid())
  raisonSociale String
  siret         String  @unique
  adresse       String
  email         String
  telephone     String?
  numeroTVA     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factures  Facture[]
  recus     Recu[]
  das2      DAS2[]
  documents Document[]

  @@map("entreprises")
}

// ─── APPORTEUR ──────────────────────────────────────────────────────────────
// type : "pro" | "particulier"
model Apporteur {
  id            String   @id @default(cuid())
  nom           String
  email         String   @unique
  type          String   @default("particulier")
  siret         String?
  dateNaissance String?
  lieuNaissance String?
  adresse       String?
  iban          String?
  telephone     String?
  createdAt     DateTime @default(now())

  commissions   Commission[]
  contrats      Contrat[]
  notifications Notification[]
  kanbanDeals   KanbanDeal[]
  factures      Facture[]
  recus         Recu[]
  documents     Document[]

  @@map("apporteurs")
}

// ─── DEAL ────────────────────────────────────────────────────────────────────
// statut : "DRAFT" | "SIGNED" | "LOST" | "CANCELLED"
model Deal {
  id      String @id @default(cuid())
  titre   String
  montant Float
  statut  String @default("DRAFT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commission  Commission?
  contrats    Contrat[]
  invitations ClientInvitation[]

  @@map("deals")
}

// ─── COMMISSION ──────────────────────────────────────────────────────────────
// statut : "PENDING" | "TO_PAY" | "PAID"
model Commission {
  id           String    @id @default(cuid())
  montant      Float
  taux         Float
  statut       String    @default("PENDING")
  entrepriseId String
  paidAt       DateTime?
  auditTrail   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId      String    @unique
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  apporteurId String
  apporteur   Apporteur @relation(fields: [apporteurId], references: [id])

  @@map("commissions")
}

// ─── CONTRAT ─────────────────────────────────────────────────────────────────
// statut : "DRAFT" | "SENT" | "UPLOADED" | "VALIDATED" | "REJECTED"
model Contrat {
  id               String    @id @default(cuid())
  statut           String    @default("DRAFT")
  token            String    @unique
  tokenExpiresAt   DateTime
  templateData     Json
  fileOriginalPath String?
  fileSignedPath   String?
  validatedAt      DateTime?
  validatedBy      String?
  rejectedReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  apporteurId String
  apporteur   Apporteur @relation(fields: [apporteurId], references: [id])
  accessLogs  ContratAccessLog[]

  @@map("contrats")
}

// ─── CONTRAT ACCESS LOG ───────────────────────────────────────────────────────
// action : "GENERATED" | "LINK_OPENED" | "SIGNED_UPLOADED" | "VALIDATED" | "REJECTED"
model ContratAccessLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  contratId String
  contrat   Contrat @relation(fields: [contratId], references: [id], onDelete: Cascade)

  @@map("contrat_access_logs")
}

// ─── [11-FE] PIPELINE KANBAN DES DEALS ──────────────────────────────────────

// statut KanbanDeal : "PROSPECT" | "CONTACTE" | "SIGNE" | "PAYE" | "ANNULE"
model KanbanDeal {
  id               String   @id @default(cuid())
  titre            String
  montant          Float
  mission          String?
  clientNom        String
  clientEmail      String?
  clientTel        String?
  statut           String   @default("PROSPECT")
  commissionGelee  Boolean  @default(false)
  position         Int      @default(0)
  commissionDealId String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apporteurId String
  apporteur   Apporteur     @relation(fields: [apporteurId], references: [id])
  documents   DealDocument[]
  messages    DealMessage[]

  @@map("kanban_deals")
}

// type DealDocument : "DEVIS" | "FACTURE" | "AUTRE"
model DealDocument {
  id         String   @id @default(cuid())
  nom        String
  type       String   @default("AUTRE")
  filePath   String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  dealId String
  deal   KanbanDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("deal_documents")
}

// auteurType : "ENTREPRISE" | "APPORTEUR"
model DealMessage {
  id         String   @id @default(cuid())
  contenu    String
  auteurId   String
  auteurType String
  lu         Boolean  @default(false)
  createdAt  DateTime @default(now())

  dealId String
  deal   KanbanDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("deal_messages")
}

// ─── [18-FE] NOTIFICATIONS ───────────────────────────────────────────────────
// type : "NOUVEAU_DEAL" | "COMMISSION_CALCULEE" | "COMMISSION_PAYEE"
model Notification {
  id        String   @id @default(cuid())
  type      String
  titre     String
  message   String
  lu        Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  userId    String
  apporteur Apporteur @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── [14-FE] DOCUMENTS FISCAUX ───────────────────────────────────────────────

// statut Facture : "EN_ATTENTE" | "PAYEE" | "ANNULEE"
model Facture {
  id          String    @id @default(cuid())
  numFacture  String    @unique
  montantHT   Float
  tauxTVA     Float     @default(20)
  montantTVA  Float
  montantTTC  Float
  dateEmission DateTime
  statut      String    @default("EN_ATTENTE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissionId  String?
  apporteurId   String
  entrepriseId  String
  apporteur     Apporteur  @relation(fields: [apporteurId], references: [id])
  entreprise    Entreprise @relation(fields: [entrepriseId], references: [id])

  @@map("factures")
}

// statut Recu : "EN_ATTENTE" | "PAYE" | "ANNULE"
model Recu {
  id          String   @id @default(cuid())
  numRecu     String   @unique
  montantBrut Float
  dateEmission DateTime
  statut      String   @default("EN_ATTENTE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissionId String?
  apporteurId  String
  entrepriseId String
  apporteur    Apporteur  @relation(fields: [apporteurId], references: [id])
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id])

  @@map("recus")
}

// statut DAS2 : "NON_GENERE" | "GENERE" | "DEPOSE"
model DAS2 {
  id                  String    @id @default(cuid())
  annee               Int
  statut              String    @default("NON_GENERE")
  s3Key               String?
  dateExport          DateTime?
  montantTotal        Float?
  nombreBeneficiaires Int       @default(0)

  createdAt DateTime @default(now())

  entrepriseId String
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id])

  @@unique([entrepriseId, annee])
  @@map("das2")
}

// type Document : "FACTURE" | "RECU" | "DAS2" | "CSV"
model Document {
  id          String   @id @default(cuid())
  type        String
  s3Key       String
  dateCreation DateTime @default(now())
  metadata    Json?

  entrepriseId String
  apporteurId  String?
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id])
  apporteur    Apporteur? @relation(fields: [apporteurId], references: [id])

  @@map("documents")
}

// ─── [17-FE] ESPACE CLIENT ────────────────────────────────────────────────────

// statut ClientInvitation : "PENDING" | "ACCESSED" | "VALIDATED" | "REFUSED"
model ClientInvitation {
  id             String   @id @default(cuid())
  email          String
  nom            String
  token          String   @unique
  tokenExpiresAt DateTime
  statut         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dealId     String
  deal       Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  evenements ClientEvenement[]

  @@map("client_invitations")
}

// type ClientEvenement : "INVITATION_ENVOYEE" | "DOSSIER_CONSULTE" | "ETAPE_VALIDEE" | "ETAPE_REFUSEE"
model ClientEvenement {
  id        String   @id @default(cuid())
  type      String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  invitationId String
  invitation   ClientInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("client_evenements")
