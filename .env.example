# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/mk42_dev

# Clerk — Auth
# Créer un compte sur https://clerk.com → Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/inscription
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/inscription/etape-2
# Configurer dans Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Resend — Emails transactionnels
# Créer un compte sur https://resend.com → API Keys
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@opus-btp.fr

# AWS S3 — Stockage fichiers (région EU Paris — RGPD)
# Bucket privé obligatoire, accès via URLs signées uniquement
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=opus-btp-documents

# Environnement
NODE_ENV=development
