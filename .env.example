# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Clerk (authentification) ─────────────────────────────────────────────────
# Clé secrète disponible sur dashboard.clerk.com
CLERK_SECRET_KEY="sk_..."
# Secret pour valider les webhooks Clerk
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── Emails (Resend) ──────────────────────────────────────────────────────────
# Clé API disponible sur resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@votre-domaine.fr"
# Email de fallback pour les notifications entreprise
ENTREPRISE_EMAIL_FALLBACK="contact@votre-domaine.fr"

# ── Stockage fichiers ────────────────────────────────────────────────────────
# Driver : "local" (dev) ou "s3" (prod)
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./storage/contrats"

# Clé AES-256 pour le chiffrement des fichiers (64 caractères hexadécimaux)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY="REMPLACER_PAR_64_CARACTERES_HEX"

# ── AWS S3 (uniquement si STORAGE_DRIVER="s3") ────────────────────────────────
# AWS_REGION="eu-west-3"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET="mk42-contrats"

# ── Divers ────────────────────────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=5
TOKEN_EXPIRY_HOURS=24
# Polling intervals en ms (optionnel)
# NEXT_PUBLIC_DEAL_CHAT_POLLING_INTERVAL=5000
# NEXT_PUBLIC_NOTIFICATION_POLLING_INTERVAL=10000
# Dev only — ID entreprise pour les stubs de développement
# STUB_ENTREPRISE_ID=""
